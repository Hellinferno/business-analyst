# Backend Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://ba_user:ba_password@localhost:5432/ba_assistant

# Redis
REDIS_URL=redis://localhost:6379/0

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Upstash (for rate limiting)
UPSTASH_REDIS_REST_URL=https://your-upstash.redis.cloud
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# R2 / S3 Storage
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=ba-assistant-files
R2_PUBLIC_URL=https://files.your-domain.com

# App
ENVIRONMENT=development
DEBUG=true
